<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>La Scène Interdite — Liberté et plaisir</title>
  <meta name="description" content="La Scène Interdite — théâtre cruel et intime de S. d’A. Liberté et plaisir." />
  <link rel="stylesheet" href="assets/styles.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>
  <header class="site-header">
    <div class="brand">
      <h1 class="title">La Scène Interdite</h1>
      <div class="subtitle">Liberté et plaisir</div>
    </div>
    <nav class="main-nav">
      <a href="#theatre">Le Théâtre</a>
      <a href="#ombres">Les Ombres</a>
      <a href="#fragments">Fragments</a>
      <a href="#jeu">Le Jeu</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <main>
    <!-- Hero com manifesto -->
    <section id="hero" class="hero">
      <div class="hero-inner">
        <div class="hero-left">
          <h2 class="manifesto" id="manifesto">Liberté et plaisir, au-delà de la douleur.</h2>
          <p class="manifesto-sub">S. d’A. — narrateur cruel, humano e teatral. Cada gesto é ritual; cada silêncio, cena.</p>
          <div class="cta-row">
            <button id="enter-btn" class="btn">Entrer au théâtre</button>
            <button id="reveal-initials" class="btn ghost">S. d’A.</button>
          </div>
        </div>
        <div class="hero-right">
          <div class="symbol-mask" aria-hidden="true">
            <div class="mask-eye left"></div>
            <div class="mask-eye right"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Le Théâtre -->
    <section id="theatre" class="panel">
      <h3 class="panel-title">Le Théâtre</h3>
      <article class="text-block">
        <p>Textes, manifestos e monólogos. Trechos curtos e cortantes que soam como cartazes de peça proibida. O teatro é íntimo: crueldade como método, presença como arma.</p>
        <div class="excerpt">
          <blockquote>«Je n’ai pas peur de la douleur; je l’invite à la table.»</blockquote>
        </div>
      </article>
      <div class="actions">
        <a class="link" href="#fragments">Lire fragments</a>
      </div>
    </section>

    <!-- Les Ombres Galeria -->
    <section id="ombres" class="panel dark">
      <h3 class="panel-title">Les Ombres</h3>
      <p class="muted">Galeria performática: máscaras, luvas, mesa, relógio parado. Fotografias estilizadas para o persona.</p>
      <div class="gallery" id="gallery">
        <!-- imagens de exemplo; substitua por suas imagens -->
        <div class="thumb" data-src="assets/img1.jpg" style="background-image:url('assets/img1-thumb.jpg')"></div>
        <div class="thumb" data-src="assets/img2.jpg" style="background-image:url('assets/img2-thumb.jpg')"></div>
        <div class="thumb" data-src="assets/img3.jpg" style="background-image:url('assets/img3-thumb.jpg')"></div>
        <div class="thumb" data-src="assets/img4.jpg" style="background-image:url('assets/img4-thumb.jpg')"></div>
      </div>
    </section>

    <!-- Fragments -->
    <section id="fragments" class="panel">
      <h3 class="panel-title">Fragments</h3>
      <div class="fragments-grid">
        <div class="fragment">
          <p class="frag-text">S. d’A. signe as cartas com uma gota de silêncio.</p>
        </div>
        <div class="fragment">
          <p class="frag-text">O relógio parou; o jogo começou.</p>
        </div>
        <div class="fragment">
          <p class="frag-text">Luvas pretas, mãos que não tremem.</p>
        </div>
        <div class="fragment">
          <p class="frag-text">Máscara por fora, abismo por dentro.</p>
        </div>
      </div>
    </section>

    <!-- Le Jeu -->
    <section id="jeu" class="panel dark">
      <h3 class="panel-title">Le Jeu</h3>
      <p class="muted">Metáforas do pôquer e do destino. Um pequeno widget simbólico para deixar o visitante sentir o risco.</p>
      <div class="game-card">
        <div class="card-row">
          <div class="card">♠</div>
          <div class="card">♥</div>
          <div class="card">♦</div>
        </div>
        <button id="shuffle-btn" class="btn">Mélanger</button>
        <p class="small muted">Cada carta carrega as iniciais <strong>S. d’A.</strong> — apenas para quem sabe ler as sombras.</p>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="panel">
      <h3 class="panel-title">Contact</h3>
      <p class="muted">Assuntos, convites para performance, ou cartas anônimas.</p>
      <form id="contact-form" class="contact-form" action="#" method="post" onsubmit="return false;">
        <label>
          <span>Nom</span>
          <input type="text" name="name" placeholder="Votre nom" required>
        </label>
        <label>
          <span>Message</span>
          <textarea name="message" rows="4" placeholder="Écrivez votre lettre..." required></textarea>
        </label>
        <div class="form-row">
          <button type="submit" id="send-btn" class="btn">Envoyer</button>
          <button type="button" id="clear-btn" class="btn ghost">Effacer</button>
        </div>
      </form>
    </section>
  </main>

  <footer class="site-footer">
    <div class="footer-left">
      <small>© <span id="year"></span> La Scène Interdite</small>
    </div>
    <div class="footer-right">
      <small class="initials">S. d’A.</small>
    </div>
  </footer>

  <!-- Modal galeria -->
  <div id="modal" class="modal" aria-hidden="true">
    <button id="modal-close" class="modal-close" aria-label="Fechar">✕</button>
    <div class="modal-content" id="modal-content"></div>
    <div class="modal-caption" id="modal-caption"></div>
  </div>

  <script src="assets/script.js"></script>
</body>
</html>
